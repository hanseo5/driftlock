{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Driftlock Final Handoff Object",
  "type": "object",
  "required": [
    "id",
    "status",
    "summary",
    "gates",
    "evidence",
    "artifacts",
    "next_action"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "status": { "const": "pass" },
    "summary": { "type": "string", "minLength": 1 },
    "gates": {
      "type": "object",
      "required": ["ux_guard", "build", "review", "amendment", "integration", "qa", "proof"],
      "properties": {
        "ux_guard": { "const": "pass" },
        "build": { "const": "pass" },
        "review": { "const": "pass" },
        "amendment": { "const": "pass" },
        "integration": { "const": "pass" },
        "qa": { "const": "pass" },
        "proof": { "const": "pass" }
      }
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "object",
      "required": ["proof_bundle", "quality_report"],
      "properties": {
        "proof_bundle": { "type": "string", "minLength": 1 },
        "quality_report": { "type": "string", "minLength": 1 }
      }
    },
    "next_action": { "type": "string", "minLength": 1 }
  }
}
