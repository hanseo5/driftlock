{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Driftlock Proof Bundle",
  "type": "object",
  "required": ["run_id", "status", "gates", "artifacts", "summary"],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "fail", "in-progress"] },
    "gates": {
      "type": "object",
      "required": ["ux_guard", "build", "review", "amendment", "integration", "qa", "proof"],
      "properties": {
        "ux_guard": { "enum": ["pass", "fail", "pending"] },
        "build": { "enum": ["pass", "fail", "pending"] },
        "review": { "enum": ["pass", "fail", "pending"] },
        "amendment": { "enum": ["pass", "fail", "pending"] },
        "integration": { "enum": ["pass", "fail", "pending"] },
        "qa": { "enum": ["pass", "fail", "pending"] },
        "proof": { "enum": ["pass", "fail", "pending"] }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["ux_guard", "build_evidence", "review_report", "quality_report", "browser_evidence", "proof_bundle"],
      "additionalProperties": { "type": "string" }
    },
    "summary": { "type": "string", "minLength": 1 }
  }
}
