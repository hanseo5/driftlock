{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Driftlock Locked Spec",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "intent",
    "goals",
    "non_goals",
    "success_criteria",
    "acceptance_scenarios",
    "decisions",
    "gate_evidence"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "const": "locked" },
    "intent": { "type": "string", "minLength": 20 },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "statement", "testable"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "testable": { "const": true }
        }
      }
    },
    "acceptance_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "given": { "type": "string", "minLength": 1 },
          "when": { "type": "string", "minLength": 1 },
          "then": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question", "answer", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gate_evidence": {
      "type": "object",
      "required": ["intent_gate", "grill_gate", "spec_gate", "analyze_gate"],
      "properties": {
        "intent_gate": { "const": "pass" },
        "grill_gate": { "const": "pass" },
        "spec_gate": { "const": "pass" },
        "analyze_gate": { "const": "pass" }
      }
    }
  }
}
