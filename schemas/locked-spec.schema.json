{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lodestar Locked Spec",
  "type": "object",
  "required": [
    "id",
    "title",
    "status",
    "intent",
    "product_shape",
    "goals",
    "non_goals",
    "success_criteria",
    "acceptance_scenarios",
    "decisions",
    "decision_policy",
    "gate_evidence"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "title": { "type": "string", "minLength": 1 },
    "status": { "const": "locked" },
    "intent": { "type": "string", "minLength": 20 },
    "product_shape": {
      "type": "object",
      "required": [
        "primary_user",
        "first_screen",
        "core_flow",
        "ux_principles",
        "approved_preview",
        "approval_source"
      ],
      "properties": {
        "primary_user": { "type": "string", "minLength": 1 },
        "first_screen": { "type": "string", "minLength": 1 },
        "core_flow": { "type": "string", "minLength": 1 },
        "ux_principles": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "approved_preview": { "const": true },
        "approval_source": { "type": "string", "minLength": 1 }
      }
    },
    "goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "non_goals": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "success_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "statement", "testable"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "statement": { "type": "string", "minLength": 1 },
          "testable": { "const": true }
        }
      }
    },
    "acceptance_scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "given", "when", "then"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "given": { "type": "string", "minLength": 1 },
          "when": { "type": "string", "minLength": 1 },
          "then": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decisions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question", "answer", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "question": { "type": "string", "minLength": 1 },
          "answer": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "decision_policy": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "required": ["class", "owner", "default_action"],
        "properties": {
          "class": {
            "enum": ["mechanical", "taste", "user-challenge", "safety-destructive"]
          },
          "owner": {
            "enum": ["harness", "user", "advisor"]
          },
          "default_action": { "type": "string", "minLength": 1 }
        }
      }
    },
    "gate_evidence": {
      "type": "object",
      "required": [
        "office_hours_gate",
        "brainstorm_gate",
        "grill_gate",
        "intent_brief_gate",
        "decision_policy_gate",
        "ux_preview_gate",
        "ux_approval_gate",
        "spec_gate",
        "analyze_gate"
      ],
      "properties": {
        "office_hours_gate": { "const": "pass" },
        "brainstorm_gate": { "const": "pass" },
        "grill_gate": { "const": "pass" },
        "intent_brief_gate": { "const": "pass" },
        "decision_policy_gate": { "const": "pass" },
        "ux_preview_gate": { "const": "pass" },
        "ux_approval_gate": { "const": "pass" },
        "spec_gate": { "const": "pass" },
        "analyze_gate": { "const": "pass" }
      }
    }
  }
}
