{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Driftlock Task Graph",
  "type": "object",
  "required": ["spec_id", "status", "tasks"],
  "properties": {
    "spec_id": { "type": "string", "minLength": 1 },
    "status": { "const": "ready" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "branch", "role", "acceptance_criteria", "covers", "dependencies"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "branch": { "type": "string", "minLength": 1 },
          "role": { "enum": ["implementer", "builder", "reviewer", "fixer"] },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "covers": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "dependencies": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
