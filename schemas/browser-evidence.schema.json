{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lodestar Browser Evidence",
  "type": "object",
  "required": [
    "run_id",
    "status",
    "mode",
    "target",
    "captured_at",
    "upstream_source",
    "viewport",
    "page",
    "checks",
    "findings",
    "metrics",
    "artifacts"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "status": { "enum": ["pass", "fail"] },
    "mode": { "enum": ["html", "url", "snapshot", "manual"] },
    "target": {
      "type": "object",
      "required": ["type", "source"],
      "properties": {
        "type": { "enum": ["url", "html", "snapshot", "manual"] },
        "source": { "type": "string", "minLength": 1 }
      }
    },
    "captured_at": { "type": "string", "minLength": 1 },
    "upstream_source": {
      "type": "object",
      "required": ["repo", "adapter", "paths"],
      "properties": {
        "repo": { "enum": ["gstack", "compound-engineering-plugin"] },
        "adapter": { "type": "string", "minLength": 1 },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "viewport": {
      "type": "object",
      "required": ["name", "width", "height"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 }
      }
    },
    "page": {
      "type": "object",
      "required": [
        "title",
        "text_sample",
        "text_length",
        "headings",
        "links",
        "buttons",
        "buttons_without_name",
        "inputs",
        "inputs_without_label",
        "images",
        "images_without_alt",
        "aria_labels",
        "html_lang"
      ],
      "properties": {
        "title": { "type": "string" },
        "text_sample": { "type": "string" },
        "text_length": { "type": "integer", "minimum": 0 },
        "headings": { "type": "array", "items": { "type": "string" } },
        "links": { "type": "integer", "minimum": 0 },
        "buttons": { "type": "integer", "minimum": 0 },
        "buttons_without_name": { "type": "integer", "minimum": 0 },
        "inputs": { "type": "integer", "minimum": 0 },
        "inputs_without_label": { "type": "integer", "minimum": 0 },
        "images": { "type": "integer", "minimum": 0 },
        "images_without_alt": { "type": "integer", "minimum": 0 },
        "aria_labels": { "type": "integer", "minimum": 0 },
        "html_lang": { "type": "boolean" }
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "load",
        "title",
        "expected_text",
        "console",
        "accessibility_baseline",
        "responsive_baseline",
        "screenshot"
      ],
      "additionalProperties": {
        "type": "object",
        "required": ["status", "summary", "evidence"],
        "properties": {
          "status": { "enum": ["pass", "fail", "warning", "not_applicable"] },
          "summary": { "type": "string", "minLength": 1 },
          "evidence": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "check", "severity", "summary", "recommendation", "source"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "check": {
            "enum": [
              "load",
              "title",
              "expected_text",
              "console",
              "accessibility_baseline",
              "responsive_baseline",
              "screenshot"
            ]
          },
          "severity": { "enum": ["critical", "high", "medium", "low"] },
          "summary": { "type": "string", "minLength": 1 },
          "recommendation": { "type": "string", "minLength": 1 },
          "source": { "type": "string", "minLength": 1 }
        }
      }
    },
    "metrics": {
      "type": "object",
      "required": [
        "total_findings",
        "critical_findings",
        "high_findings",
        "medium_findings",
        "low_findings",
        "check_pass_count",
        "check_fail_count",
        "check_warning_count",
        "check_not_applicable_count"
      ],
      "properties": {
        "total_findings": { "type": "integer", "minimum": 0 },
        "critical_findings": { "type": "integer", "minimum": 0 },
        "high_findings": { "type": "integer", "minimum": 0 },
        "medium_findings": { "type": "integer", "minimum": 0 },
        "low_findings": { "type": "integer", "minimum": 0 },
        "check_pass_count": { "type": "integer", "minimum": 0 },
        "check_fail_count": { "type": "integer", "minimum": 0 },
        "check_warning_count": { "type": "integer", "minimum": 0 },
        "check_not_applicable_count": { "type": "integer", "minimum": 0 }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
