{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Lodestar Execution Plan",
  "type": "object",
  "required": ["run_id", "spec_id", "status", "upstream_source", "task_count", "tasks", "metrics"],
  "properties": {
    "status": { "enum": ["ready", "in-progress", "done", "blocked"] },
    "upstream_source": {
      "type": "object",
      "required": ["repo", "adapter", "paths"],
      "properties": {
        "repo": { "const": "superpowers" },
        "adapter": { "type": "string", "minLength": 1 },
        "paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "task_id",
          "title",
          "branch",
          "role",
          "state",
          "status",
          "worktree",
          "state_path",
          "dependencies",
          "covers",
          "attempts",
          "gates",
          "next_allowed_events"
        ],
        "properties": {
          "task_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "branch": { "type": "string", "minLength": 1 },
          "role": { "enum": ["implementer", "builder", "reviewer", "fixer"] },
          "state": {
            "enum": [
              "TASK_READY",
              "IMPLEMENTING",
              "BUILDING",
              "REVIEWING",
              "FIXING",
              "COMPOUNDING",
              "AMENDMENT_PENDING",
              "TASK_DONE",
              "TASK_BLOCKED"
            ]
          },
          "status": { "enum": ["ready", "in-progress", "done", "blocked"] },
          "worktree": { "type": "string", "minLength": 1 },
          "state_path": { "type": "string", "minLength": 1 },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "covers": { "type": "array", "items": { "type": "string" } },
          "attempts": {
            "type": "object",
            "required": ["implementation_attempts", "build_attempts", "review_attempts", "fix_attempts", "ce_cycles"],
            "properties": {
              "implementation_attempts": { "type": "integer", "minimum": 0 },
              "build_attempts": { "type": "integer", "minimum": 0 },
              "review_attempts": { "type": "integer", "minimum": 0 },
              "fix_attempts": { "type": "integer", "minimum": 0 },
              "ce_cycles": { "type": "integer", "minimum": 0 }
            }
          },
          "gates": {
            "type": "object",
            "required": ["implementation", "build", "review", "ce", "amendment"],
            "properties": {
              "implementation": { "enum": ["pending", "pass", "fail", "not-needed"] },
              "build": { "enum": ["pending", "pass", "fail", "not-needed"] },
              "review": { "enum": ["pending", "pass", "fail", "not-needed"] },
              "ce": { "enum": ["pending", "pass", "fail", "not-needed"] },
              "amendment": { "enum": ["pending", "pass", "fail", "not-needed"] }
            }
          },
          "next_allowed_events": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "metrics": { "type": "object" }
  }
}
